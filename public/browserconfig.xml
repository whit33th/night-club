<?xml version="1.0" encoding="utf-8"?>
<browserconfig>
    <msapplication>
        <tile>
            <square70x70logo src="/web-app-manifest-192x192.png"/>
            <square150x150logo src="/web-app-manifest-192x192.png"/>
            <wide310x150logo src="/web-app-manifest-512x512.png"/>
            <square310x310logo src="/web-app-manifest-512x512.png"/>
            <TileColor>#000000</TileColor>
        </tile>
        <notification>
            <polling-uri src="/api/notifications/poll"/>
            <frequency>30</frequency>
            <cycle>1</cycle>
        </notification>
    </msapplication>
</browserconfig>